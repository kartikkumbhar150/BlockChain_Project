# Backend Environment Variables
PORT=4000
NODE_ENV=development

# Database — use docker-compose local postgres or Neon
DATABASE_URL="postgresql://dev:devpassword@localhost:5432/credentials?schema=public"

# Redis — use docker-compose local redis or Upstash
REDIS_URL="redis://localhost:6379"

# JWT Secret
JWT_SECRET="super-secret-jwt-key-change-in-production"

# IPFS Pinning (Pinata) — leave blank for mock mode
PINATA_API_KEY=""
PINATA_API_SECRET=""

# Blockchain
POLYGON_AMOY_RPC_URL="https://rpc-amoy.polygon.technology/"
PRIVATE_KEY=""

# Frontend Origin for CORS
FRONTEND_URL="http://localhost:5173"
