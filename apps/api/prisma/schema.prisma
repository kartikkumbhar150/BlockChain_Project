datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum CredentialStatus {
  PENDING
  MINTING
  MINTED
  FAILED
  REVOKED
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model Institution {
  id              String    @id @default(uuid())
  name            String
  domain          String    @unique
  contractAddress String?
  chainId         Int       @default(80002) // Amoy Testnet
  walletAddress   String?
  walletKeyRef    String?   // AWS Secrets Manager ARN
  plan            Plan      @default(STARTER)
  webhookUrl      String?
  webhookSecret   String?
  createdAt       DateTime  @default(now())

  apiKeys         ApiKey[]
  credentials     Credential[]
  templates       Template[]
  users           InstitutionUser[]
}

model ApiKey {
  id            String       @id @default(uuid())
  institutionId String
  institution   Institution  @relation(fields: [institutionId], references: [id])
  keyHash       String       @unique
  label         String
  scopes        String[]
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
}

model Credential {
  id               String           @id @default(uuid())
  institutionId    String
  institution      Institution      @relation(fields: [institutionId], references: [id])
  tokenId          BigInt?
  recipientEmail   String
  recipientName    String
  recipientWallet  String?
  credentialType   String
  achievement      String
  description      String?
  customFields     Json?
  issuedAt         DateTime         @default(now())
  expiresAt        DateTime?
  metadataIpfsCid  String?
  imageIpfsCid     String?
  status           CredentialStatus @default(PENDING)
  txHash           String?
  verificationCode String           @unique @default(cuid())
  batchId          String?
  templateId       String?
  createdAt        DateTime         @default(now())

  mintJob              MintJob?
  verificationEvents   VerificationEvent[]

  @@index([institutionId])
  @@index([verificationCode])
  @@index([recipientEmail])
}

model MintJob {
  id           String     @id @default(uuid())
  credentialId String     @unique
  credential   Credential @relation(fields: [credentialId], references: [id])
  attempts     Int        @default(0)
  lastError    String?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
}

model VerificationEvent {
  id           String     @id @default(uuid())
  credentialId String
  credential   Credential @relation(fields: [credentialId], references: [id])
  verifiedByIp String?
  source       String     @default("link") // "link" | "qr" | "api" | "embedded"
  verifiedAt   DateTime   @default(now())

  @@index([credentialId])
}

model Template {
  id            String      @id @default(uuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  name          String
  designJson    Json
  logoUrl       String?
  primaryColor  String?
  createdAt     DateTime    @default(now())
}

model InstitutionUser {
  id            String      @id @default(uuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  email         String
  passwordHash  String
  role          String      @default("admin") // "admin" | "member"
  createdAt     DateTime    @default(now())

  @@unique([institutionId, email])
}
